<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_course_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/app_tool_bar"
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:background="#03A9F4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_user_avtar"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginStart="15dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/avatar_default"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="@string/course_list_title"
            android:textColor="#171D42"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/iv_user_avtar"
            app:layout_constraintStart_toEndOf="@+id/iv_user_avtar"
            app:layout_constraintTop_toTopOf="@+id/iv_user_avtar" />

        <TextView
            android:id="@+id/iv_fetch_sign_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="#80000000"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="查签到"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_user_avtar"
            app:layout_constraintEnd_toStartOf="@+id/iv_debug_btn"
            app:layout_constraintTop_toTopOf="@+id/iv_user_avtar" />

        <TextView
            android:id="@+id/iv_debug_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="#80000000"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="LOG"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_user_avtar"
            app:layout_constraintEnd_toStartOf="@+id/tv_anti_cheat_btn"
            app:layout_constraintTop_toTopOf="@+id/iv_user_avtar" />

        <TextView
            android:id="@+id/tv_anti_cheat_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="#80000000"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="防作弊"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_user_avtar"
            app:layout_constraintEnd_toStartOf="@+id/iv_scan_btn"
            app:layout_constraintTop_toTopOf="@+id/iv_user_avtar" />

        <ImageView
            android:id="@+id/iv_scan_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="15dp"
            android:src="@drawable/ic_scan"
            app:layout_constraintBottom_toBottomOf="@+id/iv_user_avtar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_user_avtar" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
